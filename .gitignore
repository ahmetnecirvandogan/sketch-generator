# Generated dataset artifacts (per-bucket layout, issue #27).
# Bucket folders + their READMEs stay tracked so the structure is visible
# on github; everything else inside is regeneratable and gitignored.
/dataset/metadata.jsonl
/dataset/front_previews/
/dataset/manual/*
!/dataset/manual/README.md
/dataset/df3d/*
!/dataset/df3d/README.md
/dataset/procedural/*
!/dataset/procedural/README.md
# Pre-#27 flat layout (in case any of these still exist locally from old runs)
/dataset/depth/
/dataset/masks/
/dataset/normals/
/dataset/renders/
/dataset/textures/
/dataset/conditioning/
/dataset/outputs/
# Pre-rename top-level outputs/ folder (deleted; defense against accidental recreation)
/outputs/

# Generated PBR output maps
outputs/

# Python cache / build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# macOS / editor noise
.DS_Store
.idea/
.vscode/

# Claude Code local state (per-user, machine-specific)
.claude/

# Mesh buckets (issue #27)
# Folders themselves stay tracked (each holds a README.md so the structure
# is visible on github). Contents are gitignored.
# manual/ stays fully tracked (committed .obj files).
meshes/df3d/*
!meshes/df3d/README.md
meshes/procedural/*
!meshes/procedural/README.md

# Pre-#27 layout (kept commented for reference until everyone has migrated)
# output_meshes/

